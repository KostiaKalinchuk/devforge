PORT=4000
WORKSPACE_DIR=./workspace
CLAUDE_BIN=claude
CLAUDE_FLAGS=--dangerously-skip-permissions
DOCKER_PORT_RANGE_START=3100
DOCKER_PORT_RANGE_END=3999
CONTAINER_HEALTH_TIMEOUT=120
AGENT_ADAPTER=claude-code

# Model per agent (override defaults)
# Opus for planning/review (quality), Sonnet for execution (speed+cost)
AGENT_MODEL_PM=claude-sonnet-4-6
AGENT_MODEL_ARCHITECT=claude-opus-4-8
AGENT_MODEL_DEVELOPER=claude-sonnet-4-6
AGENT_MODEL_QA=claude-sonnet-4-6
AGENT_MODEL_TESTS=claude-sonnet-4-6
AGENT_MODEL_REVIEWER=claude-opus-4-8
